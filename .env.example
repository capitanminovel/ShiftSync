# .env.example — copy to .env and fill in real values (never commit .env)

# Flask
SECRET_KEY=replace-with-a-long-random-string
FLASK_DEBUG=false

# Google OAuth — from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Full callback URL — must match what you registered in Google Cloud Console
# Local:      http://localhost:5000/oauth2callback
# Production: https://your-app.onrender.com/oauth2callback
GOOGLE_REDIRECT_URI=http://localhost:5000/oauth2callback

# Timezone for calendar events (IANA tz database name)
DEFAULT_TIMEZONE=America/Chicago

# 'primary' uses the user's default calendar
CALENDAR_ID=primary
